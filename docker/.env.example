# Copy to .env and tweak. docker compose auto-loads docker/.env.
# Image name/tag (used for build, save/load, and registry push).
IMAGE_TAG=htb-kali:latest

# Docker selects the host's native architecture automatically. To build for a
# different host, uncomment and set this standard Docker variable.
# DOCKER_DEFAULT_PLATFORM=linux/amd64

# Complete official Kali base-image reference (build arg).
KALI_IMAGE=kalilinux/kali-rolling
